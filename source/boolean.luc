module boolean #(
    SIZE = 32 : SIZE > 0
)(
    input a[SIZE],
    input b[SIZE],
    input alufn[6],
    output bool[SIZE]
) {
    
    mux_4_32 mux_4[32];

  always{  
        mux_4.in = SIZEx{{alufn[3:0]}}; 
        
        repeat(i,SIZE){
            mux_4.gate[i] = c{b[i],a[i]}
            bool[i] = mux_4.out[i]
        }

  }}