module zvn_unit (
    input a31,  
    input xb31,
    input s[32],
    output z,
    output v,
    output n
) {
    sig interim
    always {
        n = s[31]
        
        v = (a31 & xb31 & !s[31]) | (!a31 & !xb31 & s[31]);
        
        interim = s[0]
        repeat(i,31){
            interim = interim|s[i+1]   
        }
        z = ~interim
    }
}